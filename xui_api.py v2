    def get_inbounds(self):

        return self.get(
            "/panel/api/inbounds/list"
        )


    def get_inbound(self, inbound_id):

        return self.get(
            f"/panel/api/inbounds/get/{inbound_id}"
        )



    # -----------------------------
    # Client creation
    # -----------------------------

    def create_client(
        self,
        inbound_id,
        email,
        client_uuid=None,
        days=30,
        traffic_gb=0
    ):

        if client_uuid is None:
            client_uuid = str(uuid.uuid4())


        expiry = 0

        if days > 0:
            expiry = int(
                (time.time() + days * 86400)
                * 1000
            )


        client = {
            "id": client_uuid,
            "email": email,
            "enable": True,
            "limitIp": 0,
            "totalGB": traffic_gb * 1024 * 1024 * 1024,
            "expiryTime": expiry,
            "flow": "",
            "subId": ""
        }


        payload = {
            "id": inbound_id,
            "settings": json.dumps({
                "clients": [
                    client
                ]
            })
        }


        return self.post(
            "/panel/api/inbounds/addClient",
            payload
        )



