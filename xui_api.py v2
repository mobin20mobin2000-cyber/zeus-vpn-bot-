    # Delete client
    # -----------------------------

    def delete_client(
        self,
        inbound_id,
        client_id
    ):

        return self.post(
            f"/panel/api/inbounds/{inbound_id}/delClient/{client_id}"
        )



    def delete_client_email(
        self,
        inbound_id,
        email
    ):

        client = self.find_client(
            inbound_id,
            email
        )


        if not client:

            return {
                "success": False,
                "error": "Client not found"
            }


        return self.delete_client(
            inbound_id,
            client["id"]
        )



    # -----------------------------
    # Enable / Disable
    # -----------------------------

    def set_status(
        self,
        inbound_id,
        email,
        status=True
    ):

        client = self.find_client(
            inbound_id,
            email
        )


        if not client:

            return {
                "success": False,
                "error": "Client not found"
            }


        client["enable"] = status


        return self.update_client(
            inbound_id,
            client["id"],
            client
        )



    def enable_client(
        self,
        inbound_id,
        email
    ):

        return self.set_status(
            inbound_id,
            email,
            True
        )



    def disable_client(
        self,
        inbound_id,
        email
    ):

        return self.set_status(
            inbound_id,
            email,
            False
        )



